<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  
  <desktops>
    <number>3</number>
  </desktops>

  <keyboard>
    <!-- Switch to desktop 1 with Ctrl+Alt+1 -->
    <keybind key="C-A-1">
      <action name="GoToDesktop">
        <to>1</to>
      </action>
    </keybind>
    
    <!-- Switch to desktop 2 with Ctrl+Alt+2 -->
    <keybind key="C-A-2">
      <action name="GoToDesktop">
        <to>2</to>
      </action>
    </keybind>

    <!-- Switch to desktop 3 with Ctrl+Alt+3 -->
    <keybind key="C-A-3">
      <action name="GoToDesktop">
        <to>3</to>
      </action>
    </keybind>
 
    <keybind key="W-1">
      <action name="DesktopSwitch">
        <desktop>1</desktop>
      </action>
    </keybind>

    <keybind key="W-2">
      <action name="DesktopSwitch">
        <desktop>2</desktop>
      </action>
    </keybind>

    <keybind key="W-3">
      <action name="DesktopSwitch">
        <desktop>3</desktop>
      </action>
    </keybind>

    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>

    <keybind key="W-l">
      <action name="Execute">
        <command>slock</command>
      </action>
   </keybind>

    <keybind key="W-t">
      <action name="Execute">
        <command>sh -c 'xterm -fullscreen -fg white -bg black -fa "JetBrainsMono Nerd Font Mono" -fs 12 -e "tmux attach-session -t 0 || tmux new-session -s 0"'</command>
      </action>
   </keybind>
   </keyboard>

  <applications>
    <!-- Send xterm to desktop 2 -->
    <application class="XTerm">
      <desktop>1</desktop>
      <focus>yes</focus>
    </application>
    
    <!-- Keep Chrome on desktop 2 -->
    <application class="Chromium">
      <maximize>yes</maximize> 
      <desktop>2</desktop>
      <focus>yes</focus>
    </application>

    <!-- Virtual Viewer on desktop 3 -->
    <application class="Remote-viewer">
      <maximize>yes</maximize>
      <desktop>3</desktop>
      <focus>yes</focus>
    </application>
  </applications>
</openbox_config>
